# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hemut
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Provider-agnostic OpenAI-compatible endpoint.
# Gemini example: LLM_API_KEY=<aistudio key>, LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Groq example:   LLM_API_KEY=<groq key>,     LLM_BASE_URL=https://api.groq.com/openai/v1/
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash

# frontend/.env.local (not this file):
# NEXT_PUBLIC_API_URL=http://localhost:8000
